# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.env

# Input and output data (we don't want to push large videos or generated text to GitHub)
data/input/*
data/output/*
!data/input/.gitkeep
!data/output/.gitkeep

# OS generated files
.DS_Store
Thumbs.db
